}

### remove address
# @name removeAddress
DELETE {{baseUrl}}/customer/address/aaa628e2-f2c1-4925-80fb-cfb65a8651b0
Authorization: Bearer {{JwtToken}}

### find one customer
# @name findOneCustomer
GET {{baseUrl}}/customer/find
Authorization: Bearer {{JwtToken}}

### find all customers
# @name findAllCustomers
GET {{baseUrl}}/customer
Authorization: Bearer {{JwtToken}}

### find all address by customer
# @name findAddressesByCustomer
GET {{baseUrl}}/customer/0e8421a6-183a-4f04-906b-6b06dade5637/address
Authorization: Bearer {{JwtToken}}

################### DELIVERY ###################

### Create delivery
# @name createDelivery
POST {{baseUrl}}/delivery/me
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "motoboy": "79984dcf-4463-424a-916a-ff4fb46027d5",
  "customer": "258ced07-07db-45c6-978b-e757c82353a9",
  "totalPurchase": 45.5,
  "deliveryTax": 6.5,
  "paymentMethod": "money"
}

### Update delivery
# @name updateDelivery
PATCH {{baseUrl}}/delivery/me/f0397249-bbc5-47ff-b7ec-ded2fd8a6b14
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "isPaid": true
}

### Delete tip
# @name deleteTip
DELETE {{baseUrl}}/tip/beda2c00-b20a-45e8-9513-6335ca173918
Authorization: Bearer {{JwtToken}}

### Delete delivery
# @name deleteDelivery
DELETE {{baseUrl}}/delivery/me/e60ff51b-7cf7-4d0e-b232-84c136e021ca
Authorization: Bearer {{JwtToken}}

### Find all owned deliveries
# @name findAllOwnedDeliveries
GET {{baseUrl}}/delivery/me
Authorization: Bearer {{JwtToken}}

### Find delivery
# @name findDelivery
GET {{baseUrl}}/delivery/3f34e129-4036-4a75-ab73-b5231fb8731e
Authorization: Bearer {{JwtToken}}

### Find all deliveries
# @name findAllDeliveries
GET {{baseUrl}}/delivery?name=Orochi&from=26-10-2025&to=27-10-2025
Authorization: Bearer {{JwtToken}}

### Find all paid deliveries
# @name findAllPaidDeliveries
GET {{baseUrl}}/delivery?isPaid=false
Authorization: Bearer {{JwtToken}}

