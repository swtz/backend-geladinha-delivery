@baseUrl = http://localhost:3001
@JwtToken = {{authLogin.response.body.accessToken}}


################### LOGIN ###################

### Auth login
# @name authLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "orochi@email.com",
  "password": "123456"
}

################### PLACE ###################

### Create place
# @name createUser
POST {{baseUrl}}/place/me
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "name": "Aonde Comercio de bebidas - PF",
  "code": "first",
  "businessName": "Deckzynn",
  "cnpj": "YYY.YYY.YYY/0001-AB",
  "cpf": "YYY.YYY.YYY-AB",
  "phone": "48999887789",
  "email": "deckzynn@email.com",
  "address": {
    "street": "Rua 13",
    "neighborhood": "Quarta linha"
  },
  "postalBox": {
    "street": "Rua Quinze",
    "neighborhood": "Docas"
  },
  "workTime": {
  "shift": "final-de-semana",
  "initHour": 9,
  "endHour": 19,
  "isDefault": true
  }
}

### Update place
# @name updateUser
PATCH {{baseUrl}}/place/me/ef0b7e03-404e-4a98-af25-b04ddaa15972
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "workTime": {
    "initHour": 18,
    "endHour": 4
  }
}

### Find place
# @name findOnePlace
GET {{baseUrl}}/place/f4970f08-da92-4a29-88f9-26c079c325d5
Authorization: Bearer {{JwtToken}}

### Add work time
# @name AddWorkTime
POST {{baseUrl}}/place/work-time?placeId=f4970f08-da92-4a29-88f9-26c079c325d5
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "shift": "feriado",
  "initHour": 9,
  "endHour": 15,
  "isDefault": false
}

################### WORK TIME ###################

### Create work time
# @name CreateWorkTime
POST {{baseUrl}}/work-time
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "shift": "madrugada",
  "initHour": 0,
  "endHour": 6
}

### Find all work times
# @name findAllWorkTimes
GET {{baseUrl}}/work-time
Authorization: Bearer {{JwtToken}}

### Remove work time
# @name removeWorkTime
DELETE {{baseUrl}}/work-time/b611a4ad-2357-4542-ab0c-9a3c0d3d9c8a
Authorization: Bearer {{JwtToken}}

################### USER ###################

### Create user
# @name createUser
POST {{baseUrl}}/user
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "name": "Rogério",
  "phone": "48999558883",
  "email": "rogerio@email.com",
  "role": "operator",
  "password": "123456",
  "workTime": {
    "shift": "madrugada",
    "initHour": 23,
    "endHour": 7
  },
  "motorcycle": "Yamaha, 2017, 300, Preta",
  "daily": 15
}

# {
#   "name": "Gabriel",
#   "email": "gabriel@email.com",
#   "phone": "(48) 99988-4469",
#   "role": "motoboy",
#   "password": "123456",
#   "motorcycle": "Yamaha, 2017, 300, Vermelha",
#   "daily": 30
# }

### Update my user
# @name updateUser
PATCH {{baseUrl}}/user/me
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  // se eu mandar o corpo incompleto,
  // vai dar erro de not-null constraint
  // na base de dados!
  "workTime": {
    "shift": "personalizado",
    "initHour": 18,
    "endHour": 4
  }
}

### Update user
# @name updateUser
PATCH {{baseUrl}}/user/e9df887c-c0ce-4426-9493-5e09c7d998d0
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "workTime": {
    "shift": "personalizado",
    "initHour": 14,
    "endHour": 20,
    "isDefault": true
  }
}

### Delete user
# @name deleteUser
DELETE {{baseUrl}}/user/b350cb30-5e71-4dc5-aa1b-1aabdd4c5599
Authorization: Bearer {{JwtToken}}

### Update user password
# @name updateUserPassword
PATCH {{baseUrl}}/user/me/password
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "currentPassword": "1234567",
  "newPassword": "123456"
}

### Read my user
# @name readMyUser
GET {{baseUrl}}/user/me
Authorization: Bearer {{JwtToken}}

### Read one user
# @name readOneUser
GET {{baseUrl}}/user/698139f9-d801-46c3-bae6-54f58c88e01e
Authorization: Bearer {{JwtToken}}

### Read all users
# @name readAllUsers
GET {{baseUrl}}/user?role=operator
Authorization: Bearer {{JwtToken}}

### Read all motoboys
# @name readAllMotoboys
GET {{baseUrl}}/user/motoboy
Authorization: Bearer {{JwtToken}}

################### CUSTOMER ###################

### Create customer
# @name createCustomer
POST {{baseUrl}}/customer
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "name": "José",
  "phone": "(48) 98855-0061",
  "address": {
    "street": "Avenida Carambolas",
    "complement": "logo ali",
    "neighborhood": "25 de março",
    "postalCode": "88955-000",
    "city": "Gaivota",
    "stateCode": "SC",
    "location": "19.8987, -155.6659"
  }
}

### Update customer
# @name updateCustomer
PATCH {{baseUrl}}/customer/874cb730-aa1e-4bc5-b8f4-736c4ccdeb34
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "name": "Rogério",
  "address" : {
    "id": "e1daf5f8-425b-4576-a3a9-640a5a5e860e",
    "isDefault": true
  }
}

### Delete customer
# @name deleteCustomer
DELETE {{baseUrl}}/customer/d1dac663-5fdf-4e1d-b6c2-2cdacfaa91ba
Authorization: Bearer {{JwtToken}}

### add address
# @name addAddress
POST {{baseUrl}}/customer/0e8421a6-183a-4f04-906b-6b06dade5637/address
