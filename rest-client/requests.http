################### PAYOUT ###################

### Preview motoboy payout
# @name previewPayout
GET {{baseUrl}}/payout/preview?name=Guilherme&from=26/10/2025&to=26/10/2025
Authorization: Bearer {{JwtToken}}

### Create motoboy payout
# @name createPayout
POST {{baseUrl}}/payout
Authorization: Bearer {{JwtToken}}
Content-Type: application/json

{
  "from": "26-10-2025",
  "to": "26-10-2025",
  "name": "Guilherme"
}

### Read payout
# @name readPayout
GET {{baseUrl}}/payout/7ed2374c-7548-4d78-a0cb-e767f19faa09
Authorization: Bearer {{JwtToken}}

### Read owned payouts
# @name readOwnedPayouts
GET {{baseUrl}}/payout/me
Authorization: Bearer {{JwtToken}}

### Read all payouts
# @name readPayout
GET {{baseUrl}}/payout
Authorization: Bearer {{JwtToken}}

### Update payout
# @name updatePayout
PATCH {{baseUrl}}/payout/041cf109-f7a9-4fd8-9bc4-90ae0f8a86d3
Authorization: Bearer {{JwtToken}}

### Update Payout.isClosed
# @name updatePayoutIsClosed
PATCH {{baseUrl}}/payout/7ed2374c-7548-4d78-a0cb-e767f19faa09/true
Authorization: Bearer {{JwtToken}}

### Remove payout
# @name removePayout
DELETE {{baseUrl}}/payout/c96c855e-6ddb-44e0-a49b-6f53b5593399
Authorization: Bearer {{JwtToken}}

